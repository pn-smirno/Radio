<Window x:Class="МоеРадио.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Радио" Height="250" Width="450">

    <StackPanel Margin="10">
        <TextBox x:Name="UrlTextBox" 
                 Height="30" 
                 Margin="0,5"
                 ToolTip="Введите URL радиостанции"
                 Text="Введите ссылку"/>

        <Button x:Name="Старт" Content="СТАРТ" Click="Старт_Click" Height="40" Margin="0,5"/>
        <Button x:Name="Стоп" Content="СТОП" Click="Стоп_Click" Height="40" Margin="0,5"/>
    </StackPanel>

</Window>
